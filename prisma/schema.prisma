// prisma/schema.prisma
// Schema do Sigly — plataforma de assinatura eletrônica
// Conforme Lei 14.063/2020 (Assinatura Simples)

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// USUÁRIOS
// ============================================================

model User {
  id               String    @id @default(cuid())
  email            String    @unique
  emailVerified    DateTime?
  name             String?
  cpf              String?
  phone            String?
  image            String?
  passwordHash     String?

  // Plano
  plan             Plan      @default(FREE)
  stripeCustomerId String?   @unique

  documents        Document[]
  sessions         Session[]
  accounts         Account[]

  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

enum Plan {
  FREE      // 3 docs/mês
  STARTER   // R$ 29 - 30 docs/mês
  PRO       // R$ 79 - 200 docs/mês
  BUSINESS  // R$ 199 - ilimitado
}

// ============================================================
// DOCUMENTOS
// ============================================================

model Document {
  id                String         @id @default(cuid())
  userId            String
  user              User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  title             String
  description       String?
  status            DocumentStatus @default(DRAFT)

  // Arquivos
  originalFileUrl   String         // Vercel Blob URL
  originalFileHash  String         // SHA-256 do PDF original
  finalFileUrl      String?        // Após todas assinaturas
  finalFileHash     String?

  // Códigos de verificação
  verificationCode  String         @unique  // ex: SGN-2026-ABC123
  verificationHash  String

  signers           Signer[]
  events            AuditEvent[]

  // Datas
  expiresAt         DateTime?
  completedAt       DateTime?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  @@index([userId])
  @@index([status])
}

enum DocumentStatus {
  DRAFT      // Sendo configurado
  SENT       // E-mails enviados
  PARTIAL    // Alguns assinaram
  COMPLETED  // Todos assinaram
  EXPIRED    // Prazo venceu
  CANCELLED
}

// ============================================================
// SIGNATÁRIOS
// ============================================================

model Signer {
  id             String         @id @default(cuid())
  documentId     String
  document       Document       @relation(fields: [documentId], references: [id], onDelete: Cascade)

  // Identificação
  name           String
  email          String
  cpf            String?
  phone          String?

  // Token único pro link de assinatura
  token          String         @unique

  // Status
  status         SignerStatus   @default(PENDING)
  order          Int            @default(0)

  // Dados da assinatura
  signedAt       DateTime?
  ipAddress      String?
  userAgent      String?
  geolocation    String?
  signatureImage String?
  signatureType  SignatureType?
  signatureHash  String?

  events         AuditEvent[]

  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@index([documentId])
  @@index([token])
}

enum SignerStatus {
  PENDING
  VIEWED
  SIGNED
  REFUSED
  EXPIRED
}

enum SignatureType {
  TYPED
  DRAWN
  UPLOADED
}

// ============================================================
// AUDITORIA (LGPD + 14.063)
// ============================================================

model AuditEvent {
  id          String         @id @default(cuid())
  documentId  String?
  document    Document?      @relation(fields: [documentId], references: [id], onDelete: SetNull)
  signerId    String?
  signer      Signer?        @relation(fields: [signerId], references: [id], onDelete: SetNull)

  type        AuditEventType
  description String
  metadata    Json?

  ipAddress   String?
  userAgent   String?
  geolocation String?

  createdAt   DateTime       @default(now())

  @@index([documentId])
  @@index([signerId])
  @@index([createdAt])
}

enum AuditEventType {
  DOCUMENT_CREATED
  DOCUMENT_SENT
  DOCUMENT_VIEWED
  SIGNER_NOTIFIED
  SIGNER_VIEWED
  SIGNER_SIGNED
  SIGNER_REFUSED
  DOCUMENT_COMPLETED
  DOCUMENT_DOWNLOADED
  DOCUMENT_VERIFIED
}

// ============================================================
// AUTH (NextAuth)
// ============================================================

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
